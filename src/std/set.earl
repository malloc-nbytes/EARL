mod Set

class Node [value] {
    @pub value = value;
    @pub left = none;
    @pub right = none;
}

@pub
class T [init] {
    root = none;

    fn constructor() {
        for i in 0..len(init) {
            insert(init[i]);
        }
    }

    @pub fn insert(value) {
        this.__insert(this.root, value);
    }

    @pub fn contains(value) {
        return this.__contains(this.root, value);
    }

    @pub fn remove(value) {
        if this.root.is_some() {
            @ref let left = this.root.unwrap().left;
            @ref let right = this.root.unwrap().right;

            if left.is_some() && right.is_some() {
                right.unwrap().left = left;
            }
        }
    }

    @pub fn dump() {
        this.__dump(this.root);
    }

    fn __dump(@ref cur) {
        if cur.is_none() == false {
            this.__dump(cur.unwrap().left);
            print(cur.unwrap().value);
            this.__dump(cur.unwrap().right);
        }
    }

    fn __contains(@ref cur, value) {
        if cur.is_none() {
            return false;
        }
        if value > cur.unwrap().value {
            return this.__contains(cur.right, value);
        }
        else if value < cur.unwrap().value {
            return this.__contains(cur.left, value);
        }
        return true;
    }

    fn __insert(@ref cur, value) {
        if cur.is_none() {
            cur = some(Node(value));
        }
        else if value > cur.unwrap().value {
            this.__insert(cur.unwrap().right, value);
        }
        else if value < cur.unwrap().value {
            this.__insert(cur.unwrap().left, value);
        }
    }
}
